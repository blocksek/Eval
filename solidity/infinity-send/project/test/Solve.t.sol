pragma solidity ^0.8.0;

import {Test} from "forge-std/Test.sol";
import {Challenge} from "src/Challenge.sol";
import {Deploy} from "script/Deploy.s.sol";
import {Solve} from "script/Solve.s.sol";

contract SolveTest is Test, Solve {
    Challenge challenge;
    address player;

    // MONEY_MOVES runtime bytecode
    bytes constant MONEY_MOVES_CODE =
        hex"";

    function setUp() public {
        player = makeAddr("player");

        vm.etch(0x6b28050C71313e4Cce8886EBEE6946B4CA0F0b9A, MONEY_MOVES_CODE);

        Deploy deploy = new Deploy();
        challenge = Challenge(deploy._deploy(player));
    }

    function test_solve() public {
        vm.startPrank(player);
        solve(address(challenge), player);
        vm.stopPrank();
        assertTrue(challenge.isSolved());
    }
}
