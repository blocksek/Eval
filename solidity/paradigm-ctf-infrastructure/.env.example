# CTF Infrastructure Environment Variables
# Copy this file to .env and configure for your environment

# =============================================================================
# Development Settings
# =============================================================================

# Public URL where the anvil proxy is accessible
# Used by challenge launchers to provide RPC URLs to players
PUBLIC_HOST=http://localhost:8545

# =============================================================================
# Ticket Validation (for production/integration with ctf-bot-be)
# =============================================================================

# URL of the ticket validation API
# When using ctf-bot-be locally:
#   TICKET_API_URL=http://host.docker.internal:3000/api/internal/check-ticket
# Default (Paradigm production):
#   TICKET_API_URL=https://ctf.paradigm.xyz/api/internal/check-ticket
TICKET_API_URL=

# =============================================================================
# Challenge Launcher Settings
# =============================================================================

# Environment mode: local, dev, or prod
# - local: No ticket validation, team_id="local"
# - dev: Static ticket validation (ticket="dev2023", team_id="dev")
# - prod: Full ticket validation via TICKET_API_URL
ENV=local

# Challenge identifier (required for prod mode)
CHALLENGE_ID=

# Fork URL for mainnet forking (optional)
ETH_RPC_URL=

# Instance timeout in seconds (default: 3600 = 60 minutes)
TIMEOUT=3600

# Challenge flag
FLAG=WCTF{example_flag}

# =============================================================================
# Backend Configuration (set automatically in docker-compose)
# =============================================================================

# Database type: redis or sqlite
# DATABASE=redis

# Redis connection URL
# REDIS_URL=redis://localhost:6379/0

# Backend type: docker or kubernetes
# BACKEND=docker
